<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_add_todo"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="14dp"
    android:paddingBottom="18dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="to do"
            android:textColor="#B4ADB7"
            android:textSize="18sp"
            android:includeFontPadding="false"
            android:fontFamily="@font/paperlogy_5medium" />

        <ImageButton
            android:id="@+id/btnSaveTodo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_add_todo"
            android:contentDescription="할 일 저장"
            android:padding="0dp"
            android:scaleType="center"
            android:adjustViewBounds="true"
            android:tint="#5B5B5B" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="제목"
            android:textColor="#111111"
            android:textSize="20sp"
            android:includeFontPadding="false"
            android:fontFamily="@font/paperlogy_5medium" />

        <EditText
            android:id="@+id/etTodoTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint=""
            android:inputType="text"
            android:minHeight="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:gravity="center_vertical"
            android:textColor="#707070"
            android:textSize="20sp"
            android:fontFamily="@font/paperlogy_2extralight"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:maxLines="1" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="72dp"
        android:background="#D9D4DC" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="메모"
            android:textColor="#111111"
            android:textSize="20sp"
            android:includeFontPadding="false"
            android:fontFamily="@font/paperlogy_5medium" />

        <EditText
            android:id="@+id/etTodoMemo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint=""
            android:inputType="text"
            android:minHeight="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:gravity="center_vertical"
            android:textColor="#707070"
            android:textSize="20sp"
            android:fontFamily="@font/paperlogy_2extralight"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:maxLines="1" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="72dp"
        android:background="#D9D4DC" />

</LinearLayout>
