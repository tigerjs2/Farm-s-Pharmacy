<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_disease_pesticide_card"
    android:elevation="3dp"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="18dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvDiseaseProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="상표명"
        android:textColor="#111111"
        android:textSize="17sp"
        android:fontFamily="@font/paperlogy_6semibold" />

    <TextView
        android:id="@+id/tvDiseaseItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="품목명"
        android:textColor="#111111"
        android:textSize="11sp"
        android:fontFamily="@font/paperlogy_4regular" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDiseaseCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="구분:   살균제  수화제(WP)"
            android:textColor="#111111"
            android:textSize="11sp"
            android:fontFamily="@font/paperlogy_4regular" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="적용 작물:"
            android:textColor="#111111"
            android:textSize="11sp"
            android:fontFamily="@font/paperlogy_4regular" />

        <TextView
            android:id="@+id/tvAppliedCrops"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:text="포도-노균병     오이-노균병     감자-노균병"
            android:textColor="#111111"
            android:textSize="11sp"
            android:singleLine="true"
            android:fontFamily="@font/paperlogy_4regular" />

    </LinearLayout>

</LinearLayout>