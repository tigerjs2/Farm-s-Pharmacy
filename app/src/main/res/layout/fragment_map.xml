<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="54dp"
        android:paddingBottom="112dp">

        <!-- 지도 -->
        <FrameLayout
            android:id="@+id/mapLayer"
            android:layout_width="222dp"
            android:layout_height="388dp"
            android:layout_gravity="center_horizontal">

            <!-- 지역 fill: border 아래에 위치 -->
            <ImageView
                android:id="@+id/ivRegionGangwon"
                android:layout_width="134dp"
                android:layout_height="117dp"
                android:layout_marginStart="72dp"
                android:layout_marginTop="9dp"
                android:src="@drawable/ic_map_region_gangwon"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/ivRegionGyeonggi"
                android:layout_width="95dp"
                android:layout_height="108dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="29dp"
                android:src="@drawable/ic_map_region_gyeonggi"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/ivRegionChungcheong"
                android:layout_width="150dp"
                android:layout_height="97dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="110dp"
                android:src="@drawable/ic_map_region_chungcheong"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/ivRegionGyeongsang"
                android:layout_width="123dp"
                android:layout_height="166dp"
                android:layout_marginStart="96dp"
                android:layout_marginTop="119dp"
                android:src="@drawable/ic_map_region_gyeongsang"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/ivRegionJeolla"
                android:layout_width="106dp"
                android:layout_height="132dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="200dp"
                android:src="@drawable/ic_map_region_jeolla"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/ivRegionJeju"
                android:layout_width="46dp"
                android:layout_height="27dp"
                android:layout_marginStart="60dp"
                android:layout_marginTop="360dp"
                android:src="@drawable/ic_map_region_jeju"
                android:importantForAccessibility="no" />

            <!-- 테두리: 항상 맨 위 -->
            <ImageView
                android:id="@+id/ivMapBorder"
                android:layout_width="222dp"
                android:layout_height="388dp"
                android:src="@drawable/ic_map_border"
                android:importantForAccessibility="no" />

            <!-- 지역명 라벨 -->
            <TextView
                android:id="@+id/tvLabelGyeonggi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="75dp"
                android:text="경기"
                android:textColor="#9FC45C"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_5medium" />

            <TextView
                android:id="@+id/tvLabelGangwon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="130dp"
                android:layout_marginTop="64dp"
                android:text="강원"
                android:textColor="#9FC45C"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_5medium" />

            <TextView
                android:id="@+id/tvLabelChungcheong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="56dp"
                android:layout_marginTop="153dp"
                android:text="충청"
                android:textColor="#9FC45C"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_5medium" />

            <TextView
                android:id="@+id/tvLabelJeolla"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="43dp"
                android:layout_marginTop="249dp"
                android:text="전라"
                android:textColor="#9FC45C"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_5medium" />

            <TextView
                android:id="@+id/tvLabelGyeongsang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="147dp"
                android:layout_marginTop="194dp"
                android:text="경상"
                android:textColor="#9FC45C"
                android:textSize="17sp"
                android:fontFamily="@font/paperlogy_5medium" />

            <TextView
                android:id="@+id/tvLabelJeju"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="73dp"
                android:layout_marginTop="364dp"
                android:text="제주"
                android:textColor="#9FC45C"
                android:textSize="13sp"
                android:fontFamily="@font/paperlogy_5medium" />

        </FrameLayout>

        <!-- 선택 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/llCropSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCrop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="전체"
                    android:textColor="#4A4327"
                    android:textSize="40sp"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="⌄"
                    android:textColor="#4A4327"
                    android:textSize="25sp"
                    android:fontFamily="@font/paperlogy_3light" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llDiseaseSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvDisease"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="흰가루병"
                    android:textColor="#4A4327"
                    android:textSize="22sp"
                    android:fontFamily="@font/paperlogy_3light"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="⌄"
                    android:textColor="#4A4327"
                    android:textSize="18sp"
                    android:fontFamily="@font/paperlogy_3light" />
            </LinearLayout>

        </LinearLayout>

        <!-- 집계 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="118dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeColor="#4A4327"
            app:strokeWidth="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="68dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#4A4327"
                        android:textSize="48sp"
                        android:fontFamily="@font/paperlogy_7bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전국"
                        android:textColor="#4A4327"
                        android:textSize="22sp"
                        android:fontFamily="@font/paperlogy_7bold"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvGyeonggiCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="경기" />
                    </LinearLayout>

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvGangwonCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="강원" />
                    </LinearLayout>

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvChungcheongCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="충청" />
                    </LinearLayout>

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvJeollaCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="전라" />
                    </LinearLayout>

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvGyeongsangCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="경상" />
                    </LinearLayout>

                    <LinearLayout style="@style/MapCountColumn">
                        <TextView
                            android:id="@+id/tvJejuCount"
                            style="@style/MapCountNumber"
                            android:text="0" />
                        <TextView
                            style="@style/MapCountLabel"
                            android:text="제주" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="주요 피해"
            android:textColor="#4A4327"
            android:textSize="24sp"
            android:fontFamily="@font/paperlogy_3light" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeColor="#4A4327"
            app:strokeWidth="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tvDamage1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="·질병 피해 없습니다!"
                    android:textColor="#4A4327"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_6semibold" />

                <TextView
                    android:id="@+id/tvDamage2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#4A4327"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>