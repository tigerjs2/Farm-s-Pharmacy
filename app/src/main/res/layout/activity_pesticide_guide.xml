<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EDE8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="58dp"
        android:paddingBottom="110dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="농약안전 사용 지침 조회"
            android:textColor="@color/primary_green"
            android:textSize="31sp"
            android:fontFamily="@font/paperlogy_5medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="병해명으로 조회하기"
            android:textColor="#777777"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/paperlogy_4regular" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="36dp"
            android:paddingEnd="24dp">

            <EditText
                android:id="@+id/etDiseaseSearch"
                android:imeOptions="actionSearch"
                android:hint="병해명을 입력하세요"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:textColor="#333333"
                android:textSize="22sp"
                android:fontFamily="@font/paperlogy_4regular" />

            <ImageView
                android:id="@+id/btnSearchDisease"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#777777" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="작물명으로 조회하기"
            android:textColor="#777777"
            android:textSize="18sp"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/paperlogy_4regular" />

        <LinearLayout
            android:id="@+id/btnCucumber"
            style="@style/CropButtonStyle"
            android:layout_marginTop="10dp">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_cucumber" />

            <TextView
                style="@style/CropTextStyle"
                android:text="오이" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnStrawberry"
            style="@style/CropButtonStyle">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_strawberry" />

            <TextView
                style="@style/CropTextStyle"
                android:text="딸기" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGrape"
            style="@style/CropButtonStyle">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_grape" />

            <TextView
                style="@style/CropTextStyle"
                android:text="포도" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPaprika"
            style="@style/CropButtonStyle">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_paprika" />

            <TextView
                style="@style/CropTextStyle"
                android:text="파프리카" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPepper"
            style="@style/CropButtonStyle">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_pepper" />

            <TextView
                style="@style/CropTextStyle"
                android:text="고추" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTomato"
            style="@style/CropButtonStyle">

            <ImageView
                style="@style/CropIconStyle"
                android:src="@drawable/ic_tomato" />

            <TextView
                style="@style/CropTextStyle"
                android:text="토마토" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>