<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="24dp"
    android:paddingBottom="64dp"
    android:clipToPadding="false"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 상단 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="안녕하세요, 오이!"
                android:textSize="36sp"
                android:fontFamily="@font/paperlogy_6semibold"
                android:textColor="@color/black"/>

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="73dp"
                android:layout_height="73dp"
                android:src="@drawable/ic_profile"/>

        </LinearLayout>

        <!-- 주간 캘린더 -->
        <LinearLayout
            android:id="@+id/llCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="월" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="16" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:src="@drawable/calendar_disease"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="화" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="17" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="수" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="18" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="목" android:textSize="13sp" android:textColor="@color/black"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:id="@+id/tvToday"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="19" android:textSize="12sp" android:textColor="@color/black"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="금" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="20" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="토" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="21" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="일" android:textSize="13sp" android:textColor="@color/gray"
                    android:fontFamily="@font/paperlogy_3light"/>
                <FrameLayout android:layout_width="51dp" android:layout_height="77dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/calendar_normal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="22" android:textSize="12sp" android:textColor="@color/gray"
                        android:fontFamily="@font/paperlogy_3light"
                        android:layout_gravity="top|center_horizontal" android:paddingTop="6dp"/>
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- 오늘의 농사 타이틀 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘의 농사"
            android:textSize="20sp"
            android:fontFamily="@font/paperlogy_4regular"
            android:textColor="@color/black"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp"/>

        <!-- 날씨 + 알림 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="16dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="현재 날씨"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_1thin"
                    android:textColor="@color/gray"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp">

                    <ImageView
                        android:id="@+id/ivWeatherIcon"
                        android:layout_width="51dp"
                        android:layout_height="51dp"
                        android:src="@drawable/ic_rainy"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7°"
                        android:textSize="70sp"
                        android:fontFamily="@font/paperlogy_3light"
                        android:textColor="@color/black"
                        android:paddingStart="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="강수량" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_1thin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1mm" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_3light"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="습도" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_1thin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="80%" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_3light"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="풍속" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_1thin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1%" android:textSize="15sp" android:textColor="@color/black"
                            android:fontFamily="@font/paperlogy_3light"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- 알림 카드 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="16dp"
                android:layout_marginStart="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="알림"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_1thin"
                    android:textColor="@color/gray"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="노균병 발병 주의..."
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:textColor="@color/black"
                    android:background="@drawable/card_gray"
                    android:padding="8dp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="질병 발생"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_1thin"
                    android:textColor="@color/black"
                    android:paddingTop="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3건"
                    android:textSize="46sp"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:textColor="@color/black"
                    android:gravity="end"
                    android:paddingEnd="8dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- 오늘 할 일 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="86dp"
            android:orientation="horizontal"
            android:background="@drawable/card_green"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="노균병 예방 다코닐 살포하기"
                    android:textSize="20sp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:textColor="@color/black"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="하우스 환기하고 온습도 조절!!"
                    android:textSize="15sp"
                    android:fontFamily="@font/paperlogy_1thin"
                    android:textColor="@color/black"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <ImageView
                android:layout_width="77dp"
                android:layout_height="77dp"
                android:src="@drawable/ic_check"
                android:padding="8dp"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- 오늘의 안전 타이틀 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘의 안전"
                android:textSize="20sp"
                android:fontFamily="@font/paperlogy_4regular"
                android:textColor="@color/black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="더보기"
                android:textSize="13sp"
                android:fontFamily="@font/paperlogy_1thin"
                android:textColor="@color/gray"/>

        </LinearLayout>

        <!-- 안전 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white2"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="예취작업은 오른쪽에서 왼쪽으로 한다."
                android:textSize="12sp"
                android:fontFamily="@font/paperlogy_6semibold"
                android:textColor="@color/black"
                android:paddingBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/safety_farmer"
                    android:scaleType="centerCrop"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 예취날을 무리하게 휘두르거나 지면에 닿지 않도록 한다."
                        android:textSize="10sp"
                        android:fontFamily="@font/paperlogy_4regular"
                        android:textColor="@color/black"
                        android:paddingBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 핸들은 양손으로 잡고 반드시 오른쪽에서 왼쪽방향으로 한다."
                        android:textSize="10sp"
                        android:fontFamily="@font/paperlogy_4regular"
                        android:textColor="@color/black"
                        android:paddingBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 왼쪽에서 오른쪽으로 작업할 경우 돌, 나무그루터기 등에 예취날이 부딪힐 경우 예취날이 작업자에게 튀어 올라 위험하게 된다."
                        android:textSize="10sp"
                        android:fontFamily="@font/paperlogy_4regular"
                        android:textColor="@color/black"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>