<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:nestedScrollingEnabled="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 이런 증상을 보여요 -->
        <TextView
            android:id="@+id/symptomTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="이런 증상을 보여요"
            android:textSize="36sp"
            android:fontFamily="@font/paperlogy_7bold" />

        <!-- 증상 사진 2장 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <ImageView
                android:id="@+id/ivSymptom1"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:scaleType="centerCrop"
                android:background="#E8E8E8"
                android:contentDescription="증상 사진 1" />

            <ImageView
                android:id="@+id/ivSymptom2"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:background="#E8E8E8"
                android:contentDescription="증상 사진 2" />

        </LinearLayout>

        <!-- 증상 목록 컨테이너 (Kotlin에서 동적 추가) -->
        <LinearLayout
            android:id="@+id/symptomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp" />

        <!-- 이렇게 대처해요 -->
        <TextView
            android:id="@+id/actionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="이렇게 대처해요"
            android:textSize="36sp"
            android:fontFamily="@font/paperlogy_7bold" />

        <!-- 대처 목록 컨테이너 (Kotlin에서 동적 추가) -->
        <LinearLayout
            android:id="@+id/actionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>