<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EDE8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="58dp"
        android:paddingBottom="110dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="“오이” 등록 농약 안내"
            android:textColor="#777777"
            android:textSize="31sp"
            android:fontFamily="@font/paperlogy_5medium" />

        <!-- 첫 번째 병해 아코디언 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_pesticide_section"
            android:elevation="3dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/diseaseHeader"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tvDiseaseName1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="병해명"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:fontFamily="@font/paperlogy_5medium" />

                <TextView
                    android:id="@+id/tvArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌃"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:fontFamily="@font/paperlogy_4regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/diseaseContentArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#111111" />

                <LinearLayout
                    android:id="@+id/pesticideContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 두 번째 병해 아코디언 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_pesticide_section"
            android:elevation="3dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/diseaseHeader2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tvDiseaseName2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="병해명"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:fontFamily="@font/paperlogy_5medium" />

                <TextView
                    android:id="@+id/tvArrow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:fontFamily="@font/paperlogy_4regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/diseaseContentArea2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#111111" />

                <LinearLayout
                    android:id="@+id/pesticideContainer2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 세 번째 병해 아코디언 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_pesticide_section"
            android:elevation="3dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/diseaseHeader3"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tvDiseaseName3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="병해명"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:fontFamily="@font/paperlogy_5medium" />

                <TextView
                    android:id="@+id/tvArrow3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:fontFamily="@font/paperlogy_4regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/diseaseContentArea3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#111111" />

                <LinearLayout
                    android:id="@+id/pesticideContainer3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>