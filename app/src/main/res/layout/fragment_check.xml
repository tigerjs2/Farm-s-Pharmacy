<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFEB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="70dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="지난 기록 확인하기"
            android:textSize="48sp"
            android:textColor="@color/primary_green"
            android:fontFamily="@font/paperlogy_3light"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="조회하고 싶은 작물을 선택해주세요."
            android:textSize="20sp"
            android:textColor="#C0B5BF"
            android:fontFamily="@font/paperlogy_3light"
            android:layout_marginBottom="32dp"/>

        <!-- 1행: 오이, 딸기 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btnCucumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_cucumber"
                android:layout_marginEnd="16dp"
                android:contentDescription="오이"/>

            <ImageButton
                android:id="@+id/btnStrawberry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_strawberry"
                android:contentDescription="딸기"/>

        </LinearLayout>

        <!-- 2행: 파프리카, 포도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btnPaprika"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_paprika"
                android:layout_marginEnd="16dp"
                android:contentDescription="파프리카"/>

            <ImageButton
                android:id="@+id/btnGrape"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_grape"
                android:contentDescription="포도"/>

        </LinearLayout>

        <!-- 3행: 고추, 토마토 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnPepper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_pepper"
                android:layout_marginEnd="16dp"
                android:contentDescription="고추"/>

            <ImageButton
                android:id="@+id/btnTomato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/b_tomato"
                android:contentDescription="토마토"/>

        </LinearLayout>

        <!-- 촬영하기 버튼 -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/b_cam_camera"
            android:layout_gravity="center_horizontal"
            android:contentDescription="촬영하기"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>